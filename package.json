* {
  box-sizing: border-box;
}
html, body, #root {
  margin: 0;
  min-height: 100%;
}
body {
  background: #07131a;
  color: #fff;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
button {
  font: inherit;
}
.container {
  width: min(1200px, calc(100% - 48px));
  margin: 0 auto;
}
.narrow {
  width: min(900px, calc(100% - 48px));
}
.app-shell {
  min-height: 100vh;
  background: #07131a;
  color: white;
}
.site-header {
  position: sticky;
  top: 0;
  z-index: 40;
  border-bottom: 1px solid rgba(255,255,255,.08);
  background: rgba(7,19,26,.9);
  backdrop-filter: blur(14px);
}
.nav-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 0;
}
.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  background: transparent;
  border: 0;
  color: white;
  cursor: pointer;
}
.brand-mark {
  width: 44px;
  height: 44px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #7ff6d6, #35d6ff, #4de08f);
  color: #07131a;
  font-weight: 800;
}
.brand-name {
  font-size: 20px;
  font-weight: 700;
}
.brand-sub {
  font-size: 11px;
  letter-spacing: .35em;
  text-transform: uppercase;
  color: #78efd8;
}
.desktop-nav {
  display: flex;
  align-items: center;
  gap: 20px;
}
.nav-link, .footer-link {
  background: transparent;
  border: 0;
  color: rgba(255,255,255,.68);
  cursor: pointer;
}
.nav-link.active,
.nav-link:hover,
.footer-link:hover {
  color: white;
}
.header-cta, .primary-btn {
  border: 0;
  border-radius: 999px;
  padding: 12px 20px;
  font-weight: 700;
  cursor: pointer;
}
.header-cta {
  background: white;
  color: #07131a;
}
.primary-btn {
  background: linear-gradient(90deg, #7ff6d6, #35d6ff, #4de08f);
  color: #07131a;
}
.secondary-btn {
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 999px;
  padding: 12px 20px;
  font-weight: 700;
  cursor: pointer;
  color: white;
  background: rgba(255,255,255,.04);
}
.mobile-toggle {
  display: none;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.1);
  background: transparent;
  color: white;
  padding: 10px;
  cursor: pointer;
}
.mobile-nav {
  display: none;
  border-top: 1px solid rgba(255,255,255,.08);
  padding: 12px 24px 18px;
}
.mobile-nav-link {
  width: 100%;
  margin-bottom: 10px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.1);
  background: rgba(255,255,255,.04);
  color: rgba(255,255,255,.85);
  padding: 14px 16px;
  text-align: left;
  cursor: pointer;
}
.hero {
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(20,220,200,0.18), transparent 28%),
              radial-gradient(circle at left, rgba(0,120,255,0.12), transparent 22%);
}
.hero-grid, .two-grid, .two-grid-uneven, .program-grid, .stats-grid, .feature-grid, .footer-grid {
  display: grid;
  gap: 24px;
}
.hero-grid {
  position: relative;
  grid-template-columns: 1.1fr .9fr;
  align-items: center;
  padding: 80px 0 100px;
  gap: 56px;
}
.hero h1 {
  margin: 24px 0 0;
  max-width: 780px;
  font-size: clamp(2.8rem, 7vw, 5rem);
  line-height: 1.03;
}
.hero-copy {
  max-width: 700px;
  margin-top: 24px;
  font-size: 18px;
  line-height: 1.9;
  color: rgba(255,255,255,.7);
}
.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 36px;
}
.pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border-radius: 999px;
  border: 1px solid rgba(120,239,216,.2);
  background: rgba(120,239,216,.1);
  padding: 10px 14px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: #bffcf3;
}
.hero-panel-wrap {
  position: relative;
}
.hero-panel-glow {
  position: absolute;
  inset: -16px;
  border-radius: 32px;
  background: linear-gradient(135deg, rgba(20,220,200,.2), rgba(53,214,255,.04));
  filter: blur(28px);
}
.hero-panel {
  position: relative;
  border-radius: 32px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.05);
  padding: 24px;
  backdrop-filter: blur(20px);
}
.card {
  border-radius: 28px;
  border: 1px solid rgba(255,255,255,.08);
  background: #0b1820;
  padding: 28px;
}
.card-light {
  background: rgba(255,255,255,.05);
}
.panel-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  border-bottom: 1px solid rgba(255,255,255,.08);
  padding-bottom: 20px;
}
.panel-top h3, .card h3 {
  margin: 8px 0 0;
  font-size: 30px;
}
.tag {
  border-radius: 16px;
  background: rgba(77,224,143,.14);
  color: #83ffbf;
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 700;
}
.trust-grid, .list-grid, .faq-grid, .field-list, .footer-links {
  display: grid;
  gap: 12px;
}
.trust-item, .check-row {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
  padding: 16px;
  color: rgba(255,255,255,.78);
}
.trust-item svg, .check-row svg, .accent-icon {
  color: #78efd8;
  flex-shrink: 0;
}
.section {
  padding: 80px 0;
}
.section-alt {
  border-top: 1px solid rgba(255,255,255,.08);
  border-bottom: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
}
.section-header {
  max-width: 760px;
}
.section-header h2 {
  margin: 16px 0 0;
  font-size: clamp(2rem, 4vw, 3.25rem);
  line-height: 1.1;
}
.section-header p, .muted, .card p {
  color: rgba(255,255,255,.65);
  line-height: 1.9;
}
.eyebrow, .footer-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: #78efd8;
}
.stats-grid {
  grid-template-columns: repeat(3, 1fr);
}
.feature-grid {
  grid-template-columns: repeat(4, 1fr);
  margin-top: 48px;
}
.two-grid {
  grid-template-columns: repeat(2, 1fr);
  margin-top: 48px;
}
.two-grid-uneven {
  grid-template-columns: .8fr 1.2fr;
  margin-top: 48px;
}
.program-grid {
  grid-template-columns: repeat(3, 1fr);
  margin-top: 48px;
}
.card-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 12px;
}
.stat-value {
  font-size: 42px;
  font-weight: 700;
}
.form-grid {
  display: grid;
  gap: 18px;
  grid-template-columns: repeat(2, 1fr);
}
label {
  display: block;
  margin-bottom: 8px;
  font-size: 14px;
  color: rgba(255,255,255,.7);
}
.mock-input, .mock-textarea {
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,.1);
  background: rgba(255,255,255,.03);
  padding: 14px 16px;
  color: rgba(255,255,255,.35);
}
.mock-textarea {
  min-height: 130px;
}
.form-block {
  margin: 18px 0 24px;
}
.field-list-item {
  font-size: 14px;
  color: rgba(255,255,255,.75);
}
.faq-item {
  text-align: left;
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,.08);
  background: #0b1820;
  padding: 24px;
  color: white;
  cursor: pointer;
}
.faq-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.faq-q {
  font-size: 20px;
  font-weight: 700;
}
.contact-list, .footer-contact {
  display: grid;
  gap: 14px;
}
.contact-list div, .footer-contact div {
  display: flex;
  align-items: center;
  gap: 10px;
}
.page-cta {
  margin-top: 32px;
}
.site-footer {
  border-top: 1px solid rgba(255,255,255,.08);
  background: rgba(0,0,0,.18);
}
.footer-grid {
  grid-template-columns: 1.2fr .8fr .8fr;
  padding: 56px 0;
}
.footer-title {
  font-size: 28px;
  font-weight: 700;
}
.footer-copy {
  max-width: 420px;
}
.small {
  font-size: 14px;
}

@media (max-width: 980px) {
  .desktop-nav {
    display: none;
  }
  .mobile-toggle, .mobile-nav {
    display: block;
  }
  .hero-grid, .feature-grid, .stats-grid, .two-grid, .two-grid-uneven, .program-grid, .footer-grid, .form-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .container, .narrow {
    width: min(100% - 32px, 1200px);
  }
  .section {
    padding: 64px 0;
  }
  .hero-grid {
    padding: 64px 0 80px;
  }
  .panel-top {
    flex-direction: column;
  }
}
